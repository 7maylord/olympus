# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — Supabase (or any Postgres connection string)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Option B — individual params (used when DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=olympus

# ── Chain ─────────────────────────────────────────────────────────────────────
MANTLE_RPC_URL=https://dream-rpc.mantle.network
CHAIN_ID=50312

# Block to start indexing from (set to your deploy block to skip history)
START_BLOCK=0

# ── Contract addresses (from forge script output) ─────────────────────────────
TASK_REGISTRY_ADDRESS=
AGENT_REGISTRY_ADDRESS=
BOUNTY_ESCROW_ADDRESS=
EXECUTION_VERIFIER_ADDRESS=

# ── Keeper wallet (pays gas for expireTask + finalizeExecution) ───────────────
# Never commit the real key. Use a funded throwaway wallet on testnet.
KEEPER_PRIVATE_KEY=
