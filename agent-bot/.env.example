# Agent wallet private key (must have STT for gas + stake + claim bonds)
PRIVATE_KEY=0x...

# Somnia RPC
RPC_URL=https://dream-rpc.somnia.network

# Olympus API (indexer backend)
API_URL=http://localhost:3000

# Contract addresses (Somnia testnet)
TASK_REGISTRY_ADDRESS=0xce0E28dE3216fa08D332439B3F4ECaeeE783d0eb
AGENT_REGISTRY_ADDRESS=0xFA88cd15765bD93703D8CC7a42d83fFC6FAb01d3

# Which task types this agent handles (comma-separated)
CAPABILITIES=SWAP,TRANSFER,COMPOUND,MONITOR

# Agent metadata URI (JSON describing your agent)
METADATA_URI=https://raw.githubusercontent.com/your-repo/agent-metadata.json

# How often to poll for new tasks (ms)
POLL_INTERVAL_MS=6000
