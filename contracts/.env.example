# ── Deployer ──────────────────────────────────────────────────────────────────
# Never commit the real .env. Copy this file to .env and fill in values.
PRIVATE_KEY=

# ── Network ───────────────────────────────────────────────────────────────────
SOMNIA_RPC_URL=https://rpc.ankr.com/somnia_testnet/<your-api-key>
ETHERSCAN_API_KEY=

# ── Contract config ───────────────────────────────────────────────────────────
# Address that receives listing fees and forfeited claim bonds.
# Defaults to the deployer address if left blank.
TREASURY_ADDRESS=

# Somnia's native on-chain AI compute contract address on testnet.
# AgentManager: 0x77F6dC5924652e32DBa0B4329De0a44a2C95691E
# Leave blank (defaults to address(0)) to skip on-chain trigger evaluation and settle optimistically.
SOMNIA_AGENTS_ADDRESS=0x77F6dC5924652e32DBa0B4329De0a44a2C95691E

# Base URL for the price-feed API queried by SomniaAgentsAdapter.
PRICE_FEED_BASE_URL=https://api.price-feed.xyz/v1/
